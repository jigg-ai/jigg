---
// Neutral line glyphs used inside artifact-thumbnail placeholders. These stand
// in for real artifact screenshots (BRIEF: thumbnails are placeholders, not a
// design element) — deliberately generic and monochrome.
interface Props {
  category: string;
  size?: number;
}
const { category, size = 22 } = Astro.props;

const paths: Record<string, string> = {
  chatbots: '<path d="M4 5h16v10H9l-4 4v-4H4z"/><path d="M8.5 10h.01M12 10h.01M15.5 10h.01"/>',
  video: '<rect x="3" y="6" width="12" height="12" rx="2"/><path d="M15 10l6-3v10l-6-3z"/>',
  websites: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 8h18"/><path d="M6.5 6.2h.01M9 6.2h.01"/>',
  automation: '<path d="M20 11a8 8 0 10-1.6 5"/><path d="M20 5v5h-5"/>',
  writing: '<path d="M4 20l4-1L19 8l-3-3L5 16z"/><path d="M14 7l3 3"/>',
  research: '<circle cx="10.5" cy="10.5" r="6"/><path d="M20 20l-5.2-5.2"/>',
  design: '<circle cx="8" cy="8" r="4"/><rect x="12" y="12" width="8" height="8" rx="1.5"/>',
  agents: '<path d="M12 3l1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8z"/><path d="M18 15l.9 2.1L21 18l-2.1.9L18 21l-.9-2.1L15 18l2.1-.9z"/>',
};
const d = paths[category] ?? paths.websites;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
></svg>
