---
// Nav follows the BRIEF (Builds · Tools · About · Subscribe), not the mockup's
// category-name nav: categories are filters on /builds, never top-level items.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [
  { href: '/builds', label: 'Builds' },
  { href: '/tools', label: 'Tools' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container bar">
    {/* Accessible name is set explicitly to exactly "Jigg.AI" — it matches the
        visible wordmark (so WCAG 2.5.3 Label in Name holds) and doesn't depend on
        content-derived naming. The monogram tile stays aria-hidden so it never
        bleeds into the name as "JJigg.AI". */}
    <a class="brand" href="/" aria-label="Jigg.AI">
      <span class="tile" aria-hidden="true">J</span>
      <span class="wordmark">Jigg.AI</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={['nav-link', { active: isActive(l.href) }]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/subscribe" class="btn btn--primary cta">Subscribe</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(1.2) blur(6px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.25rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
  }
  .tile {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: var(--brand-tint);
    color: var(--brand);
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1;
  }
  .wordmark {
    font-family: var(--font-serif);
    font-weight: 560;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.9rem, 2.4vw, 1.75rem);
    flex-wrap: wrap;
  }
  .nav-link {
    text-decoration: none;
    color: var(--ink-muted);
    font-size: 0.95rem;
    padding: 0.2rem 0;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active { color: var(--ink); font-weight: 540; }
  .cta { padding: 0.55em 1em; }

  @media (max-width: 30rem) {
    .cta { padding: 0.5em 0.85em; font-size: 0.9rem; }
    .nav { gap: 0.95rem; }
  }
</style>
