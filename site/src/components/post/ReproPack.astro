---
import EmailCapture from '../EmailCapture.astro';

// Two-tier "Reproduce this": public substantiation shown openly on the page (enough
// to verify every claim without a download), plus the gated downloadable pack (the
// lead magnet). ALL content is build-specific and passed in — there are no content
// defaults, so nothing leaks between builds. Keep it build-agnostic; see
// builds/_template/repro/README.md for the shape.
//
// Colour note: rendered in the BRAND tint, not the mockup's blue (brand + status
// only — no decorative colour creep).
interface Props {
  /** Public items shown openly — enough to verify claims with no download. */
  onPage: string[];
  /** One-line description of the downloadable pack. */
  packDescription: string;
  /** What the pack actually contains. */
  packContents: string[];
  intro?: string;
}
const {
  onPage,
  packDescription,
  packContents,
  intro = 'Enough on this page to check every claim yourself — no download required:',
} = Astro.props;
---

<div class="repro">
  <p class="intro">{intro}</p>
  <ul class="on-page">
    {onPage.map((it) => <li>{it}</li>)}
  </ul>

  <aside class="pack">
    <p class="kicker">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z" /><path d="M4 7.5l8 4.5 8-4.5M12 12v9" />
      </svg>
      The downloadable pack
    </p>
    <p class="pack-desc">{packDescription}</p>
    <p class="pack-label">In the pack</p>
    <ul class="pack-contents">
      {packContents.map((it) => <li>{it}</li>)}
    </ul>
    <EmailCapture
      cta="Get the pack"
      variant="onBrand"
      note="Free. The full reproducible pack, plus one honest build per new post."
    />
  </aside>
</div>

<style>
  .intro { color: var(--ink-muted); }
  .on-page { margin-top: 0.85rem; }

  .pack {
    margin-top: 1.9rem;
    background: var(--brand-tint);
    border: 1px solid color-mix(in srgb, var(--brand) 22%, var(--border));
    border-radius: var(--radius);
    padding: 1.5rem 1.6rem;
  }
  .kicker {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--brand);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
  }
  .pack-desc { color: var(--ink); max-width: 46rem; }
  .pack-label {
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 1.15rem;
  }
  .pack .pack-contents {
    margin: 0.55rem 0 1.4rem;
    padding-left: 1.2rem;
    columns: 2;
    column-gap: 2.5rem;
  }
  .pack .pack-contents li { margin-top: 0.3rem; break-inside: avoid; }

  @media (max-width: 34rem) {
    .pack .pack-contents { columns: 1; }
  }
</style>
