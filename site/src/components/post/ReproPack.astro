---
import EmailCapture from '../EmailCapture.astro';

// "Reproduce this exactly" — public substantiation + the gated pack (lead magnet).
// NOTE: the mockup renders this callout in light blue; that would be a fourth,
// meaning-less hue. Per the colour ruling we render it in the BRAND tint instead
// (brand + status only — no decorative colour creep).
interface Props {
  title?: string;
  blurb?: string;
  items: string[];
}
const {
  title = 'Reproduce this exactly',
  blurb = "Everything you'd need to rebuild it: the task definition, the flow, the knowledge-base structure, every prompt, and the full test set.",
  items,
} = Astro.props;
---

<aside class="repro">
  <p class="kicker">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z" /><path d="M4 7.5l8 4.5 8-4.5M12 12v9" />
    </svg>
    {title}
  </p>
  <p class="blurb">{blurb}</p>
  <ul class="items">
    {items.map((it) => <li class="mono">{it}</li>)}
  </ul>
  <EmailCapture
    cta="Get the pack"
    variant="onBrand"
    note="Free. The full reproducible pack, plus one honest build per new post."
  />
</aside>

<style>
  .repro {
    background: var(--brand-tint);
    border: 1px solid color-mix(in srgb, var(--brand) 22%, var(--border));
    border-radius: var(--radius);
    padding: 1.5rem 1.6rem;
  }
  .kicker {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--brand);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
  }
  .blurb { color: var(--ink); max-width: 44rem; }
  .items {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
  }
  .items li {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand) 18%, var(--border));
    border-radius: var(--radius-pill);
    padding: 0.35em 0.75em;
    color: var(--ink);
  }
</style>
