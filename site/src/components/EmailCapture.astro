---
// Newsletter signup, wired to Buttondown's public embed endpoint. This posts a
// plain form (no API key in the browser) to Buttondown, which then shows its
// "confirm your subscription" page in a new tab (double opt-in).
//
// Set BUTTONDOWN_USERNAME to the newsletter's Buttondown username — it's the one
// place that needs it, and every EmailCapture on the site uses it.
const BUTTONDOWN_USERNAME = 'jiggAI';
const action = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;

interface Props {
  cta?: string;
  note?: string;
  placeholder?: string;
  variant?: 'default' | 'onBrand';
}
const {
  cta = 'Get the builds',
  note = 'One honest build in your inbox — prompts, costs, and files included. One email per new build, no filler.',
  placeholder = 'you@email.com',
  variant = 'default',
} = Astro.props;
---

<form class:list={['capture', variant]} action={action} method="post" target="_blank">
  <input
    type="email"
    name="email"
    inputmode="email"
    autocomplete="email"
    aria-label="Email address"
    placeholder={placeholder}
    required
  />
  <input type="hidden" name="embed" value="1" />
  <button type="submit" class="btn btn--primary">{cta}</button>
  <p class="note">{note}</p>
</form>

<style>
  .capture {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    align-items: start;
  }
  .capture input[type='email'] {
    font: inherit;
    padding: 0.75em 0.9em;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--ink);
    width: 100%;
    min-width: 0;
  }
  .capture input[type='email']:focus-visible { outline: 2px solid var(--brand); outline-offset: 1px; }
  .capture .btn { white-space: nowrap; }
  .note {
    grid-column: 1 / -1;
    color: var(--ink-muted);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }
  .onBrand input[type='email'] {
    background: var(--surface);
    border-color: color-mix(in srgb, var(--brand) 30%, var(--border-strong));
  }

  @media (max-width: 30rem) {
    .capture { grid-template-columns: 1fr; }
    .capture .btn { width: 100%; justify-content: center; }
  }
</style>
