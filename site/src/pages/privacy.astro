---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'privacy');
if (!entry) throw new Error('Missing content entry: pages/privacy.md');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="container container--prose page">
    <h1>{entry.data.title}</h1>
    <div class="prose stack">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .page { padding-top: clamp(2rem, 5vw, 3.5rem); }
  .page h1 { font-size: var(--step-h1); font-weight: 460; }
  .page .prose { margin-top: 1.5rem; }
  /* Content from <Content /> isn't scoped to this component, so reach it with
     :global. Give the opening paragraph the larger "lead" treatment, matching About. */
  .page :global(.prose > p:first-of-type) {
    font-size: 1.2rem;
    color: var(--ink-muted);
  }
</style>
